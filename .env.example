# ── Resend (lead magnet email delivery) ─────────────────────────
# 1. Create a free key at https://resend.com/api-keys and paste it below.
#    With ONLY this key set, the audit + booking forms work immediately,
#    sending from Resend's shared "onboarding@resend.dev" sender.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2. Where new lead notifications are delivered.
#    IMPORTANT: until you verify your own domain (step 3), Resend test mode
#    only delivers to the email address that owns your Resend account.
#    So set this to that same email while testing.
LEAD_NOTIFICATION_EMAIL=info@shandigitalmarketing.com

# 3. (Optional) Once you've verified your domain at https://resend.com/domains,
#    set a branded sender. Leave this unset to use onboarding@resend.dev.
# RESEND_FROM_EMAIL="Shan Digital Marketing <leads@shandigitalmarketing.com>"

# ── Site ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://shandigitalmarketing.com
