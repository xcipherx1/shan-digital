# ============================================================
#  Marketing site (lead magnet email delivery via Resend)
# ============================================================
# Create a free key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Where new lead notifications are delivered.
LEAD_NOTIFICATION_EMAIL=info@shandigitalmarketing.com
# Optional branded sender (needs a verified domain). Defaults to onboarding@resend.dev.
# RESEND_FROM_EMAIL="Shan Digital Marketing <leads@shandigitalmarketing.com>"
NEXT_PUBLIC_SITE_URL=https://shandigitalmarketing.com

# ============================================================
#  Secure browser dialer (/dialer)
# ============================================================
# Postgres (Neon or Vercel Postgres). Use the pooled connection string.
DATABASE_URL=

# Auth.js — generate with:  npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=
# Canonical URL of the deployment (used by Auth.js).
NEXTAUTH_URL=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_TWIML_APP_SID=
TWILIO_CALLER_ID=

# Public base URL Twilio webhooks are signed against (usually same as NEXTAUTH_URL).
PUBLIC_BASE_URL=
# Comma-separated allowed dial prefixes (widen later if needed).
ALLOWED_DIAL_PREFIXES=+44

# Seed users: JSON array of { "email", "name", "password", "role"? }
# e.g. [{"email":"agent@shandigitalmarketing.com","name":"Agent One","password":"change-me","role":"admin"}]
SEED_USERS_JSON=
